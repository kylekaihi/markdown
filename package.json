{
  "name": "minimal-markdown-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "check:uploader": "wrangler deploy --dry-run --config worker/wrangler.jsonc",
    "deploy:uploader": "wrangler deploy --config worker/wrangler.jsonc",
    "preview": "astro preview",
    "test:worker": "node --test worker/test/*.test.mjs",
    "upload:image": "node scripts/r2-upload-image.mjs",
    "verify": "node scripts/verify-site.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "astro": "^5.15.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "wrangler": "^4.90.1"
  }
}
